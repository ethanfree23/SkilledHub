# Copy to .env and fill in. Never commit real keys.

# Live publishable key — required for production builds (set in CI/hosting too).
VITE_STRIPE_PUBLISHABLE_KEY=

# Test publishable key — used only when running `npm run dev` (overrides VITE_STRIPE_PUBLISHABLE_KEY in dev).
VITE_STRIPE_PUBLISHABLE_KEY_TEST=

# Google Maps JavaScript API (Maps JS + Geocoder for dashboard job pins). Optional locally; without it the dashboard falls back to an embed preview.
VITE_GOOGLE_MAPS_API_KEY=
